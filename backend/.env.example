# SourceLogic - backend environment template
# Copy this file to .env and fill in values

# Required: OpenAI API key for gpt-4o / gpt-4-turbo / gpt-3.5-turbo
OPENAI_API_KEY=sk-...

# SQLAlchemy async database URL.
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/codechat.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sourcelogic

# Path where ChromaDB persists its vector index.
CHROMA_PATH=./data/chroma_db

# Allowed CORS origins (JSON array). Default covers local dev only; set in production.
# CORS_ORIGINS=["https://your-domain.com","https://app.your-domain.com"]

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Optional: restrict workspace root_path to a base directory (path traversal guard).
# Unset = any absolute path is allowed (safe for local single-user use).
# Set this in production deployments to prevent users from indexing arbitrary server paths.
# WORKSPACE_ALLOWED_BASE=/home/user/projects

# Chat rate limit (slowapi format). Default: 20 requests/minute per IP.
# CHAT_RATE_LIMIT=20/minute

# Auth mode: "dev" (trust X-Tenant-ID header) or "api_key" (validate X-API-Key against DB).
# Use "dev" for local single-user use. Use "api_key" for multi-tenant deployments.
# AUTH_MODE=dev

# Admin secret for /admin/* endpoints (generate and provision API keys for tenants).
# Leave unset to disable admin endpoints entirely.
# ADMIN_SECRET=generate-a-strong-random-secret-here

# Optional: JWT secret for production auth provider integration (Bearer token mode).
# Leave unset to disable JWT. If set, GET_CURRENT_TENANT will validate Bearer tokens.
# Requires PyJWT: uv add pyjwt. See dependencies.py for JWT implementation.
# JWT_SECRET=your-jwt-secret-key-here-min-32-chars
